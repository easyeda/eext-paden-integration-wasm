{
	"name": "pro-api-sdk",
	"version": "1.3.2",
	"description": "嘉立创EDA & EasyEDA 专业版扩展 API 开发工具",
	"author": "JLCEDA <support@lceda.cn>",
	"license": "Apache-2.0",
	"homepage": "https://pro.lceda.cn/",
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"compile": "rimraf ./dist && ts-node ./config/esbuild.prod.ts",
		"lint": "eslint",
		"fix": "eslint --fix",
		"build": "npm run compile && npm run build:geometry-bridge && npm run build:wasm && ts-node ./build/packaged.ts",
		"build:geometry-bridge": "node scripts/build-geometry-bridge.js",
		"build:wasm": "node scripts/build-wasm.js",
		"build:wasm:dev": "node scripts/build-wasm.js --dev",
		"postbuild:wasm": "node scripts/copy-wasm-assets.js"
	},
	"dependencies": {
		"clipper2-wasm": "^0.4.0",
		"earcut": "^3.0.2"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.2.33",
		"@tracespace/parser": "5.0.0-alpha.0",
		"@tracespace/plotter": "5.0.0-alpha.0",
		"@types/earcut": "^3.0.0",
		"@types/fs-extra": "^11.0.4",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jszip": "^3.10.1",
		"lint-staged": "^16.2.3",
		"rimraf": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
